# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/*
!/out/index.html

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# service account / credential files that sometimes get dropped in the repo root
*firebase-adminsdk*.json
*service-account*.json
*.pem
*.p12

# database
dev.db

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/app/generated/prisma
project-tmp.json*
__MACOSX

# capacitor / android
/android/.gradle/
/android/app/build/
/android/local.properties
/android/build/
/android/captures/

# capacitor / ios
/ios/App/Pods/
/ios/App/build/
/ios/App/DerivedData/
