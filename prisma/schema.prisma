generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        String  @id @default(cuid())
  name      String
  email     String  @unique
  password  String
  avatar    String  @default("https://i.pravatar.cc/150?img=70")
  bio       String  @default("")
  latitude  Float   @default(-34.46)
  longitude Float   @default(-58.53)
  isPremium Boolean @default(false)
  credits   Int     @default(5)
  balance   Float   @default(0.0)
  role        String  @default("USER")
  bannedAt    DateTime?
  ratingAvg   Float   @default(0)
  ratingCount Int     @default(0)
  createdAt   DateTime @default(now())

  clothingItems    ClothingItem[]
  swipes           Swipe[]
  matchesAsA       Match[]       @relation("UserA")
  matchesAsB       Match[]       @relation("UserB")
  messagesSent     Message[]
  transactions     Transaction[]
  reportsMade      Report[]      @relation("ReportsMade")
  reportsReceived  Report[]      @relation("ReportsReceived")
  reportsReviewed  Report[]      @relation("ReportsReviewed")
  ratingsGiven     Rating[]      @relation("RatingsGiven")
  ratingsReceived  Rating[]      @relation("RatingsReceived")
}

model ClothingItem {
  id          String   @id @default(cuid())
  title       String
  description String   @default("")
  size        String
  brand       String
  condition   String
  category    String   @default("Ropa")
  imageUrl    String
  price       Float?
  isBumped    Boolean  @default(false)
  bumpedAt    DateTime?
  latitude    Float
  longitude   Float
  userId      String
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
  swipes      Swipe[]
  reports     Report[]
}

model Swipe {
  id           String       @id @default(cuid())
  swiperId     String
  targetItemId String
  type         String
  createdAt    DateTime     @default(now())
  swiper       User         @relation(fields: [swiperId], references: [id])
  targetItem   ClothingItem @relation(fields: [targetItemId], references: [id])

  @@unique([swiperId, targetItemId])
}

model Match {
  id        String    @id @default(cuid())
  userAId   String
  userBId   String
  createdAt DateTime  @default(now())
  userA     User      @relation("UserA", fields: [userAId], references: [id])
  userB     User      @relation("UserB", fields: [userBId], references: [id])
  messages  Message[]
  reports   Report[]
  ratings   Rating[]
}

model Message {
  id        String   @id @default(cuid())
  matchId   String
  senderId  String
  text      String
  createdAt DateTime @default(now())
  match     Match    @relation(fields: [matchId], references: [id])
  sender    User     @relation(fields: [senderId], references: [id])
}

model Transaction {
  id          String    @id @default(cuid())
  userId      String
  amount      Float
  type        String
  status      String    @default("PENDING")
  meta        String    @default("{}")
  availableAt DateTime?
  withdrawnAt DateTime?
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id])
}

model Report {
  id             String    @id @default(cuid())
  reporterId     String
  reportedUserId String?
  itemId         String?
  matchId        String?
  reason         String
  details        String    @default("")
  status         String    @default("PENDING")
  resolution     String    @default("")
  reviewedById   String?
  createdAt      DateTime  @default(now())
  reviewedAt     DateTime?

  reporter     User          @relation("ReportsMade", fields: [reporterId], references: [id])
  reportedUser User?         @relation("ReportsReceived", fields: [reportedUserId], references: [id])
  reviewedBy   User?         @relation("ReportsReviewed", fields: [reviewedById], references: [id])
  item         ClothingItem? @relation(fields: [itemId], references: [id])
  match        Match?        @relation(fields: [matchId], references: [id])
}

model Rating {
  id            String   @id @default(cuid())
  matchId       String
  raterId       String
  ratedUserId   String
  score         Int
  comment       String   @default("")
  createdAt     DateTime @default(now())

  match     Match @relation(fields: [matchId], references: [id])
  rater     User  @relation("RatingsGiven", fields: [raterId], references: [id])
  ratedUser User  @relation("RatingsReceived", fields: [ratedUserId], references: [id])

  @@unique([matchId, raterId])
}
