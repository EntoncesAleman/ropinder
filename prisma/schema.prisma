generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        String  @id @default(cuid())
  name      String
  email     String  @unique
  password  String
  avatar    String  @default("https://i.pravatar.cc/150?img=70")
  bio       String  @default("")
  latitude  Float   @default(-34.46)
  longitude Float   @default(-58.53)
  isPremium Boolean @default(false)
  credits   Int     @default(5)
  balance   Float   @default(0.0)
  createdAt DateTime @default(now())

  clothingItems ClothingItem[]
  swipes        Swipe[]
  matchesAsA    Match[]       @relation("UserA")
  matchesAsB    Match[]       @relation("UserB")
  messagesSent  Message[]
  transactions  Transaction[]
}

model ClothingItem {
  id          String   @id @default(cuid())
  title       String
  description String   @default("")
  size        String
  brand       String
  condition   String
  category    String   @default("Ropa")
  imageUrl    String
  price       Float?
  isBumped    Boolean  @default(false)
  bumpedAt    DateTime?
  latitude    Float
  longitude   Float
  userId      String
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
  swipes      Swipe[]
}

model Swipe {
  id           String       @id @default(cuid())
  swiperId     String
  targetItemId String
  type         String
  createdAt    DateTime     @default(now())
  swiper       User         @relation(fields: [swiperId], references: [id])
  targetItem   ClothingItem @relation(fields: [targetItemId], references: [id])

  @@unique([swiperId, targetItemId])
}

model Match {
  id        String    @id @default(cuid())
  userAId   String
  userBId   String
  createdAt DateTime  @default(now())
  userA     User      @relation("UserA", fields: [userAId], references: [id])
  userB     User      @relation("UserB", fields: [userBId], references: [id])
  messages  Message[]
}

model Message {
  id        String   @id @default(cuid())
  matchId   String
  senderId  String
  text      String
  createdAt DateTime @default(now())
  match     Match    @relation(fields: [matchId], references: [id])
  sender    User     @relation(fields: [senderId], references: [id])
}

model Transaction {
  id        String   @id @default(cuid())
  userId    String
  amount    Float
  type      String
  status    String   @default("PENDING")
  meta      String   @default("{}")
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}
